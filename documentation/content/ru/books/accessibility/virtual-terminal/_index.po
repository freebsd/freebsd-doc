"# Text light gray to black\n"
"kern.vt.color.7.rgb=\"0,0,0\"\n"
msgstr ""
"# Text light gray to black\n"
"kern.vt.color.7.rgb=\"0,0,0\"\n"

#. type: delimited block . 4
#: documentation/content/en/books/accessibility/virtual-terminal/_index.adoc:177
#, no-wrap
